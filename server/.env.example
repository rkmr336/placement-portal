PORT=5000

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/placement-portal?appName=Cluster0

# JWT Secret - change this to a strong random string in production
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# Gemini AI (optional - for AI resume analyzer)
GEMINI_API_KEY=your_gemini_api_key_here

# Frontend URL (for CORS) - set after deploying frontend
CLIENT_URL=http://localhost:3000
